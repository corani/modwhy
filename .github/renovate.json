{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "config:recommended"
  ],
  "postUpdateOptions": [
    "gomodTidy"
  ],
  "prConcurrentLimit": 1,
  "automergeType": "pr",
  "platformAutomerge": true,
  "commitMessagePrefix": "chore(deps):",
  "dependencyDashboardLabels": [
    "renovate"
  ],
  "enabledManagers": [
    "gomod",
    "github-actions"
  ],
  "lockFileMaintenance": {
    "enabled": true,
    "automerge": true
  },
  "packageRules": [
    {
      "groupName": "go-toolchain",
      "description": "Update go directive to the newest version",
      "matchPackageNames": [
        "go"
      ],
      "rangeStrategy": "bump"
    },
    {
      "groupName": "all patch dependencies",
      "groupSlug": "all-patch",
      "matchUpdateTypes": [
        "patch",
        "digest"
      ],
      "labels": [
        "renovate",
        "patch-update"
      ],
      "automerge": true
    },
    {
      "matchUpdateTypes": [
        "minor"
      ],
      "labels": [
        "renovate",
        "minor-update"
      ],
      "automerge": true
    },
    {
      "matchUpdateTypes": [
        "major"
      ],
      "labels": [
        "renovate",
        "major-update"
      ],
      "dependencyDashboardApproval": true
    }
  ]
}
